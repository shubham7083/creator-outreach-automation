APP_NAME="Creator Brand Outreach Automation"
APP_ENV="development"
LOG_LEVEL="INFO"
DATABASE_URL="sqlite+aiosqlite:///./data/outreach.sqlite3"
CACHE_DIR="./cache"
OUTPUT_DIR="./outputs"
PROMPTS_DIR="./prompts"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GMAIL_SENDER_EMAIL=""
YOUTUBE_API_KEY=""
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""

APOLLO_API_KEY=""
APOLLO_BASE_URL="https://api.apollo.io"
GITHUB_TOKEN=""

HTTP_TIMEOUT_SECONDS="30"
HTTP_MAX_RETRIES="3"
PLAYWRIGHT_HEADLESS="true"
PLAYWRIGHT_CHROMIUM_EXECUTABLE=""
CREATOR_ANALYSIS_CACHE_TTL_SECONDS="86400"
CREATOR_ANALYSIS_YOUTUBE_VIDEO_COUNT="20"
CREATOR_ANALYSIS_INSTAGRAM_POST_COUNT="12"
CREATOR_ANALYSIS_KEYWORD_LIMIT="30"
SIMILAR_DISCOVERY_CACHE_TTL_SECONDS="86400"
SIMILAR_DISCOVERY_GOOGLE_RESULT_LIMIT="10"
SIMILAR_DISCOVERY_YOUTUBE_RESULT_LIMIT="10"
SIMILAR_DISCOVERY_MAX_CREATORS_TO_ANALYZE="10"
BRAND_DISCOVERY_CACHE_TTL_SECONDS="86400"
BRAND_DISCOVERY_RESULTS_PER_SOURCE="8"
BRAND_DISCOVERY_MAX_BRANDS="40"
BRAND_SCORING_CACHE_TTL_SECONDS="86400"
BRAND_SCORING_MIN_SCORE="6"
BRAND_SCORING_MAX_RETRIES="3"
CONTACT_DISCOVERY_CACHE_TTL_SECONDS="86400"
CONTACT_DISCOVERY_MAX_CONTACTS="25"
CONTACT_DISCOVERY_RESULTS_PER_ROLE="5"
OUTREACH_CACHE_TTL_SECONDS="86400"
OUTREACH_MAX_WORDS="150"
