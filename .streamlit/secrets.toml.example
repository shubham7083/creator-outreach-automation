# Copy these values into Streamlit Community Cloud secrets.
# Do not commit a real secrets.toml file.

APP_NAME = "Creator Brand Outreach Automation"
APP_ENV = "production"
LOG_LEVEL = "INFO"
DATABASE_URL = "sqlite+aiosqlite:///./data/outreach.sqlite3"
CACHE_DIR = "./cache"
OUTPUT_DIR = "./outputs"
PROMPTS_DIR = "./prompts"

OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-4.1"

GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""
GOOGLE_REFRESH_TOKEN = ""
GMAIL_SENDER_EMAIL = ""
YOUTUBE_API_KEY = ""
GOOGLE_SEARCH_API_KEY = ""
GOOGLE_SEARCH_ENGINE_ID = ""

APOLLO_API_KEY = ""
APOLLO_BASE_URL = "https://api.apollo.io"
GITHUB_TOKEN = ""

HTTP_TIMEOUT_SECONDS = "30"
HTTP_MAX_RETRIES = "3"
PLAYWRIGHT_HEADLESS = "true"
PLAYWRIGHT_CHROMIUM_EXECUTABLE = "/usr/bin/chromium"
